class Solution {
    public int minOperations(int[][] grid, int x) {
        int m = grid.length, n = grid[0].length;
        int[] arr = new int[m * n];
        
        int k=0;
        int rem=grid[0][0] % x;
             for (int[]row : grid) {
            for (int val:row) {
                if (val%x!=rem)return -1;
                arr[k++]=val;
            }
        }
        Arrays.sort(arr);        
        int median = arr[arr.length / 2];
        int ops = 0;
        for (int val : arr) {
            ops += Math.abs(val - median) / x;
        }
        return ops;
    }
}
