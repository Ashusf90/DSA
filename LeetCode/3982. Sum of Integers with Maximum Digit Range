class Solution {
    public int maxDigitRange(int[] nums) {
        int maxrange=-1;
        int sum=0;
        for(int c:nums){
            int t=c,mn=9,mx=0;
            while(t>0){
                int d=t%10;
                mn = Math.min(mn, d);
                mx = Math.max(mx, d);
                t/=10;
            }
            int range=mx-mn;
                        if (range > maxrange) {

                maxrange = range;

                sum = c;

            } else if (range == maxrange) {

                sum += c;

            }
        }
        return sum;
    }
}
