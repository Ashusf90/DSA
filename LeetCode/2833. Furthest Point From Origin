class Solution {
    public int furthestDistanceFromOrigin(String moves) {
        int left=0;
        int right=0;
        int blank=0;
        for(char move:moves.toCharArray()){
            if(move=='L'){
                left++;
            }else if(move=='R'){
                right++;
            }else{
                blank++;
            }
        }
        return Math.abs(right - left) + blank;
    }
}
